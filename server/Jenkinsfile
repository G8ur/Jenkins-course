pipeline {
    agent any

    stages {
        stage('With Docker Node') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    ls -la 
                    node --version
                    npm --version
                    npm i
                    # Removed --watch because it will hang the pipeline
                    node index.js 
                '''
            }
        }
    }
}