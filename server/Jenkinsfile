pipeline {
    agent any

    stages {
        stage('w/o docker') {
            {
                agent{
                    docker{
                        image 'node:18-alpine'
                        reuseNode true
                    }
                }
            }
            steps {
                sh '''
                    ls -la 
                    node --version
                    npm --version
                    npm i 
                    node --watch index.js
                '''
            }
        }
    }
}
