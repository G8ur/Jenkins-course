pipeline {
    agent none // Do not pick a node globally

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    // We remove reuseNode and add a custom mount path
                    args '-u root'
                }
            }
            steps {
                // 1. Force the code to pull inside the current container context
                checkout scm
                
                sh '''
                    echo "Current directory: $(pwd)"
                    
                    # 2. Check if files exist
                    ls -la 
                    
                    if [ -f package.json ]; then
                        npm install
                        npm run build --if-present
                    else
                        echo "--- DEBUGGING ---"
                        echo "Looking for package.json in the whole system..."
                        find / -name package.json 2>/dev/null | head -n 5
                        exit 1
                    fi
                '''
            }
        }
    }
}