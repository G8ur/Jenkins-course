pipeline {
    agent any

    options {
        // CRITICAL: This tells Jenkins NOT to try pulling the Git code immediately.
        // If we don't skip this, Git crashes before we have a chance to clean the folder.
        skipDefaultCheckout()
    }

    stages {
        stage('Self-Heal (Wipe Workspace)') {
            agent {
                docker {
                    image 'alpine' // Very small, fast image just for cleaning
                    reuseNode true
                    // We use root ONE LAST TIME exclusively to delete the stubborn files
                    args '-u root' 
                }
            }
            steps {
                sh '''
                    echo "Force-cleaning the workspace of any root-owned files..."
                    # Wipe everything including hidden git and npm folders
                    rm -rf ./*
                    rm -rf ./.git
                    rm -rf ./.npm-cache
                '''
            }
        }

        stage('Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                    // REMOVED: args "-u root:root"
                    // We now run as the standard Jenkins user so files are safe to delete.
                }
            }
            steps {
                // Now that the workspace is 100% clean, pull the code safely
                checkout scm
                
                sh '''
                    # CRITICAL FIX: Direct npm cache to a local folder 
                    # so it doesn't try to write to the protected /.npm root directory
                    export npm_config_cache="$(pwd)/.npm-cache"
                    
                    cd server
                    
                    npm ci
                    npm run build
                    ls -la
                '''
            }
        }

        stage('Test') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                    // No root arguments needed here either
                }
            }
            steps {
                sh '''
                    echo "Test stage"
                    export npm_config_cache="$(pwd)/.npm-cache"
                    cd server
                    
                    # Verify the build output exists
                    if [ -f build/index.html ] || [ -d dist ]; then
                        echo "Build file successfully found!"
                    else
                        echo "Error: Build output missing!"
                        exit 1
                    fi
                    
                    # npm test --if-present
                '''
            }
        }
    }
    post{
        always{
            junit testResults: 'server/test-results/junit.xml', 
        }
    }
}