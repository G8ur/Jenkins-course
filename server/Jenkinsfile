pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                    /* REMOVED the -v mount to fix the "Duplicate mount" error.
                       Kept -u root to ensure permission to write node_modules.
                    */
                    args '-u root'
                }
            }
            steps {
                // Pull code from GitHub into the host workspace
                checkout scm
                
                sh '''
                    echo "Current directory: $(pwd)"
                    ls -la 
                    
                    node --version
                    npm --version
                    
                    # If package.json exists, install and build
                    if [ -f package.json ]; then
                        npm install
                        npm run build --if-present
                    else
                        echo "Error: package.json not found in $(pwd)"
                        exit 1
                    fi
                '''
            }
        }
    }
}