pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                    args '-u root'
                }
            }
            steps {
                checkout scm
                sh '''
                    ls -la 
                    node --version
                    npm --version
                    cd server
                    npm ci
                    npm run build
                    ls -la
                '''
            }
        }
    }
}